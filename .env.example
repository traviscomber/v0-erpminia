# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# PostgreSQL Connection
POSTGRES_URL=your_postgres_connection_string
POSTGRES_PRISMA_URL=your_postgres_prisma_connection_string
POSTGRES_URL_NON_POOLING=your_postgres_non_pooling_connection_string
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=your_host
POSTGRES_DATABASE=postgres

# Admin Setup Token (change this in production)
ADMIN_INIT_TOKEN=dev_init_token_change_me_in_production

# n3uralia ERP Configuration
NEXT_PUBLIC_APP_NAME=n3uralia ERP mining
NEXT_PUBLIC_APP_VERSION=0.1.0
